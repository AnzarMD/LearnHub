NODE_ENV=development
PORT=8000
API_PREFIX=/api/v1
DATABASE_URL=postgresql://postgres:1234@localhost:5432/learnhub_db
JWT_ACCESS_SECRET=change_this_access_secret_in_production_min_32_chars
JWT_REFRESH_SECRET=change_this_refresh_secret_in_production_min_32_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
UPLOAD_PATH=./uploads
MAX_FILE_SIZE_MB=20
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
BCRYPT_ROUNDS=12
SWAGGER_ENABLED=true
REDIS_URL=redis://localhost:6379
REDIS_ENABLED=false